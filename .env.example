# Copy this file to .env. Never commit .env or any credential-bearing variant.

# Image and localhost-only ports
AHS_IMAGE_TAG=local
AHS_SAMPLE_PORT=8501
AHS_PRODUCTION_PORT=8501
AHS_DATA_DIR=./data

# Build only the provider integrations you intend to use.
# Examples: ui | ui,model-openai | ui,model-anthropic | ui,model-bedrock
AHS_MODEL_EXTRAS=ui

# Planner provider: demo, openai, anthropic, or bedrock
AHS_MODEL_PROVIDER=demo
AHS_MODEL_NAME=

# OpenAI or an approved OpenAI-compatible HTTPS gateway
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_FILE=

# AWS Bedrock. Prefer a mounted profile/SSO cache or short-lived credentials.
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_ACCESS_KEY_ID_FILE=
AWS_SECRET_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY_FILE=
AWS_SESSION_TOKEN=
AWS_SESSION_TOKEN_FILE=

# Production CSV paths inside the container. Defaults match /data/ahs.
AHS_HOUSEHOLD_CSV=/data/ahs/household.csv
AHS_MORTGAGE_CSV=/data/ahs/mortgage.csv
AHS_PROJECTS_CSV=/data/ahs/projects.csv

# Optional DuckDB override used by config/docker.production.toml
AHS_DUCKDB_MEMORY_LIMIT=4GB
