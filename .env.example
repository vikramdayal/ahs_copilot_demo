# Copy this file to .env. Do not commit .env or any credential-bearing variant.

# Image and ports
AHS_IMAGE_TAG=local
AHS_SAMPLE_PORT=8501
AHS_PRODUCTION_PORT=8501
AHS_DATA_DIR=./data
AHS_MODEL_EXTRAS=ui,model-openai,model-anthropic,model-bedrock

# Planner provider: demo, openai, anthropic, or bedrock
AHS_MODEL_PROVIDER=demo
AHS_MODEL_NAME=

# OpenAI or OpenAI-compatible gateway
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_FILE=

# AWS Bedrock. Prefer an AWS profile or short-lived credentials.
AWS_REGION=us-east-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_ACCESS_KEY_ID_FILE=
AWS_SECRET_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY_FILE=
AWS_SESSION_TOKEN=
AWS_SESSION_TOKEN_FILE=

# Production CSV paths inside the container. Defaults match /data/ahs mount.
AHS_HOUSEHOLD_CSV=/data/ahs/household.csv
AHS_MORTGAGE_CSV=/data/ahs/mortgage.csv
AHS_PROJECTS_CSV=/data/ahs/projects.csv
