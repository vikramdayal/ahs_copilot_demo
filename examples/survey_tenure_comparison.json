{
  "base_dataset": "household",
  "universe_filters": [
    {
      "column": {"dataset": "household", "column": "INTSTATUS"},
      "operator": "eq",
      "value": 1
    }
  ],
  "group_by": [
    {
      "column": {"dataset": "household", "column": "TENURE"},
      "alias": "tenure"
    }
  ],
  "estimates": [
    {
      "alias": "occupied_units",
      "statistic": "weighted_count"
    },
    {
      "alias": "high_cost_burden_pct",
      "statistic": "weighted_percentage",
      "numerator_filters": [
        {
          "column": {"dataset": "household", "column": "TOTHCPCT"},
          "operator": "ge",
          "value": 50
        }
      ],
      "denominator_filters": [
        {
          "column": {"dataset": "household", "column": "TOTHCPCT"},
          "operator": "is_not_null"
        }
      ]
    },
    {
      "alias": "mean_household_income",
      "statistic": "weighted_mean",
      "value": {"dataset": "household", "column": "HINCP"}
    }
  ],
  "suppression": {
    "policy_id": "demo_unweighted_minimums_v1",
    "minimum_unweighted_denominator": 2,
    "minimum_unweighted_numerator": 1,
    "minimum_unweighted_complement": 1,
    "action": "null_estimate"
  },
  "comparisons": {
    "mode": "reference",
    "reference_group": {"tenure": 1},
    "include_ratio": true
  }
}
