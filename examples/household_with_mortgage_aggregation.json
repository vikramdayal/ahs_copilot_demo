{
  "base_dataset": "household",
  "select": [
    {"kind": "column", "column": {"dataset": "household", "column": "CONTROL"}},
    {"kind": "column", "column": {"dataset": "mortgage", "column": "mortgage_count"}},
    {"kind": "column", "column": {"dataset": "mortgage", "column": "mortgage_total"}}
  ],
  "joins": [
    {
      "dataset": "mortgage",
      "how": "left",
      "aggregation": {
        "group_by": ["CONTROL"],
        "aggregates": [
          {"function": "count", "column": null, "alias": "mortgage_count"},
          {"function": "sum", "column": "MORTAMT", "alias": "mortgage_total"}
        ]
      }
    }
  ],
  "order_by": [{"output_alias": "CONTROL", "direction": "asc"}],
  "limit": 100
}
