{
  "$defs": {
    "DatasetEstimateMetadata": {
      "additionalProperties": false,
      "properties": {
        "logical_name": {
          "title": "Logical Name",
          "type": "string"
        },
        "source_file_id": {
          "title": "Source File Id",
          "type": "string"
        },
        "physical_path": {
          "title": "Physical Path",
          "type": "string"
        },
        "synthetic_fixture": {
          "title": "Synthetic Fixture",
          "type": "boolean"
        },
        "size_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Size Bytes"
        },
        "modified_ns": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Modified Ns"
        }
      },
      "required": [
        "logical_name",
        "source_file_id",
        "physical_path",
        "synthetic_fixture",
        "size_bytes",
        "modified_ns"
      ],
      "title": "DatasetEstimateMetadata",
      "type": "object"
    },
    "FormulaDescriptor": {
      "additionalProperties": false,
      "properties": {
        "estimate_alias": {
          "title": "Estimate Alias",
          "type": "string"
        },
        "statistic": {
          "enum": [
            "weighted_count",
            "weighted_percentage",
            "weighted_mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "numerator_formula": {
          "title": "Numerator Formula",
          "type": "string"
        },
        "denominator_formula": {
          "title": "Denominator Formula",
          "type": "string"
        },
        "estimate_formula": {
          "title": "Estimate Formula",
          "type": "string"
        },
        "missing_value_rule": {
          "title": "Missing Value Rule",
          "type": "string"
        },
        "weight_rule": {
          "title": "Weight Rule",
          "type": "string"
        }
      },
      "required": [
        "estimate_alias",
        "statistic",
        "numerator_formula",
        "denominator_formula",
        "estimate_formula",
        "missing_value_rule",
        "weight_rule"
      ],
      "title": "FormulaDescriptor",
      "type": "object"
    },
    "GroupComparison": {
      "additionalProperties": false,
      "properties": {
        "estimate_alias": {
          "title": "Estimate Alias",
          "type": "string"
        },
        "statistic": {
          "enum": [
            "weighted_count",
            "weighted_percentage",
            "weighted_mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "left_group": {
          "additionalProperties": true,
          "title": "Left Group",
          "type": "object"
        },
        "right_group": {
          "additionalProperties": true,
          "title": "Right Group",
          "type": "object"
        },
        "difference": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Difference"
        },
        "ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Ratio"
        },
        "suppressed": {
          "title": "Suppressed",
          "type": "boolean"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        },
        "inferential_test": {
          "const": "NOT_PERFORMED",
          "default": "NOT_PERFORMED",
          "title": "Inferential Test",
          "type": "string"
        },
        "standard_error": {
          "default": null,
          "title": "Standard Error",
          "type": "null"
        },
        "p_value": {
          "default": null,
          "title": "P Value",
          "type": "null"
        }
      },
      "required": [
        "estimate_alias",
        "statistic",
        "left_group",
        "right_group",
        "difference",
        "ratio",
        "suppressed",
        "reasons"
      ],
      "title": "GroupComparison",
      "type": "object"
    },
    "QualifiedColumn": {
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "column": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Column",
          "type": "string"
        }
      },
      "required": [
        "dataset",
        "column"
      ],
      "title": "QualifiedColumn",
      "type": "object"
    },
    "SuppressionDecision": {
      "additionalProperties": false,
      "properties": {
        "suppressed": {
          "title": "Suppressed",
          "type": "boolean"
        },
        "action": {
          "enum": [
            "flag",
            "null_estimate"
          ],
          "title": "Action",
          "type": "string"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "policy_id": {
          "title": "Policy Id",
          "type": "string"
        }
      },
      "required": [
        "suppressed",
        "action",
        "reasons",
        "policy_id"
      ],
      "title": "SuppressionDecision",
      "type": "object"
    },
    "SuppressionPolicy": {
      "additionalProperties": false,
      "properties": {
        "policy_id": {
          "default": "configured_unweighted_cell_thresholds_v1",
          "title": "Policy Id",
          "type": "string"
        },
        "minimum_unweighted_denominator": {
          "default": 1,
          "minimum": 0,
          "title": "Minimum Unweighted Denominator",
          "type": "integer"
        },
        "minimum_unweighted_numerator": {
          "default": 0,
          "minimum": 0,
          "title": "Minimum Unweighted Numerator",
          "type": "integer"
        },
        "minimum_unweighted_complement": {
          "default": 0,
          "minimum": 0,
          "title": "Minimum Unweighted Complement",
          "type": "integer"
        },
        "action": {
          "default": "null_estimate",
          "enum": [
            "flag",
            "null_estimate"
          ],
          "title": "Action",
          "type": "string"
        }
      },
      "title": "SuppressionPolicy",
      "type": "object"
    },
    "SurveyEstimate": {
      "additionalProperties": false,
      "properties": {
        "group": {
          "additionalProperties": true,
          "title": "Group",
          "type": "object"
        },
        "weighting_mode": {
          "enum": [
            "weighted",
            "unweighted"
          ],
          "title": "Weighting Mode",
          "type": "string"
        },
        "estimate_alias": {
          "title": "Estimate Alias",
          "type": "string"
        },
        "statistic": {
          "enum": [
            "weighted_count",
            "weighted_percentage",
            "weighted_mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "estimate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Estimate"
        },
        "weighted_numerator": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Weighted Numerator"
        },
        "weighted_denominator": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Weighted Denominator"
        },
        "unweighted_numerator": {
          "title": "Unweighted Numerator",
          "type": "integer"
        },
        "unweighted_denominator": {
          "title": "Unweighted Denominator",
          "type": "integer"
        },
        "unweighted_complement": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Unweighted Complement"
        },
        "invalid_weight_rows_excluded": {
          "title": "Invalid Weight Rows Excluded",
          "type": "integer"
        },
        "missing_value_rows_excluded": {
          "title": "Missing Value Rows Excluded",
          "type": "integer"
        },
        "suppression": {
          "$ref": "#/$defs/SuppressionDecision"
        },
        "formula": {
          "title": "Formula",
          "type": "string"
        },
        "standard_error": {
          "default": null,
          "title": "Standard Error",
          "type": "null"
        },
        "confidence_interval": {
          "default": null,
          "title": "Confidence Interval",
          "type": "null"
        }
      },
      "required": [
        "group",
        "weighting_mode",
        "estimate_alias",
        "statistic",
        "estimate",
        "weighted_numerator",
        "weighted_denominator",
        "unweighted_numerator",
        "unweighted_denominator",
        "unweighted_complement",
        "invalid_weight_rows_excluded",
        "missing_value_rows_excluded",
        "suppression",
        "formula"
      ],
      "title": "SurveyEstimate",
      "type": "object"
    },
    "SurveyExecutionMetadata": {
      "additionalProperties": false,
      "properties": {
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "request_fingerprint": {
          "title": "Request Fingerprint",
          "type": "string"
        },
        "sql_fingerprint": {
          "title": "Sql Fingerprint",
          "type": "string"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "finished_at": {
          "format": "date-time",
          "title": "Finished At",
          "type": "string"
        },
        "elapsed_ms": {
          "title": "Elapsed Ms",
          "type": "number"
        },
        "duckdb_version": {
          "title": "Duckdb Version",
          "type": "string"
        },
        "database": {
          "title": "Database",
          "type": "string"
        },
        "memory_limit": {
          "title": "Memory Limit",
          "type": "string"
        },
        "temp_directory": {
          "title": "Temp Directory",
          "type": "string"
        },
        "threads": {
          "title": "Threads",
          "type": "integer"
        },
        "datasets": {
          "items": {
            "$ref": "#/$defs/DatasetEstimateMetadata"
          },
          "title": "Datasets",
          "type": "array"
        },
        "join_contract_ids": {
          "items": {
            "type": "string"
          },
          "title": "Join Contract Ids",
          "type": "array"
        },
        "group_rows": {
          "title": "Group Rows",
          "type": "integer"
        },
        "comparisons_returned": {
          "title": "Comparisons Returned",
          "type": "integer"
        },
        "estimation_scope": {
          "enum": [
            "DESCRIPTIVE_WEIGHTED_ESTIMATES",
            "DESCRIPTIVE_UNWEIGHTED_ESTIMATES"
          ],
          "title": "Estimation Scope",
          "type": "string"
        },
        "weight_column": {
          "anyOf": [
            {
              "$ref": "#/$defs/QualifiedColumn"
            },
            {
              "type": "null"
            }
          ]
        },
        "weight_eligibility_rule": {
          "title": "Weight Eligibility Rule",
          "type": "string"
        },
        "arithmetic_rule": {
          "title": "Arithmetic Rule",
          "type": "string"
        },
        "suppression_policy": {
          "$ref": "#/$defs/SuppressionPolicy"
        },
        "variance": {
          "$ref": "#/$defs/VarianceMetadata"
        }
      },
      "required": [
        "run_id",
        "request_fingerprint",
        "sql_fingerprint",
        "started_at",
        "finished_at",
        "elapsed_ms",
        "duckdb_version",
        "database",
        "memory_limit",
        "temp_directory",
        "threads",
        "datasets",
        "join_contract_ids",
        "group_rows",
        "comparisons_returned",
        "estimation_scope",
        "weight_column",
        "weight_eligibility_rule",
        "arithmetic_rule",
        "suppression_policy"
      ],
      "title": "SurveyExecutionMetadata",
      "type": "object"
    },
    "VarianceMetadata": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "const": "NOT_ESTIMATED",
          "default": "NOT_ESTIMATED",
          "title": "Status",
          "type": "string"
        },
        "replicate_weights_used": {
          "const": false,
          "default": false,
          "title": "Replicate Weights Used",
          "type": "boolean"
        },
        "approved_method": {
          "default": null,
          "title": "Approved Method",
          "type": "null"
        },
        "standard_errors_valid": {
          "const": false,
          "default": false,
          "title": "Standard Errors Valid",
          "type": "boolean"
        },
        "message": {
          "default": "Descriptive weighted estimates only. Standard errors, confidence intervals, and significance tests are unavailable until replicate weights and an approved variance method are implemented.",
          "title": "Message",
          "type": "string"
        }
      },
      "title": "VarianceMetadata",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "estimates": {
      "items": {
        "$ref": "#/$defs/SurveyEstimate"
      },
      "title": "Estimates",
      "type": "array"
    },
    "comparisons": {
      "items": {
        "$ref": "#/$defs/GroupComparison"
      },
      "title": "Comparisons",
      "type": "array"
    },
    "generated_sql": {
      "title": "Generated Sql",
      "type": "string"
    },
    "parameterized_sql": {
      "title": "Parameterized Sql",
      "type": "string"
    },
    "parameters": {
      "items": {},
      "title": "Parameters",
      "type": "array"
    },
    "formulas": {
      "items": {
        "$ref": "#/$defs/FormulaDescriptor"
      },
      "title": "Formulas",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/SurveyExecutionMetadata"
    }
  },
  "required": [
    "estimates",
    "comparisons",
    "generated_sql",
    "parameterized_sql",
    "parameters",
    "formulas",
    "metadata"
  ],
  "title": "SurveyEstimateResult",
  "type": "object"
}