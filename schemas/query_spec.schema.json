{
  "$defs": {
    "AggregateProjection": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "aggregate",
          "default": "aggregate",
          "title": "Kind",
          "type": "string"
        },
        "function": {
          "enum": [
            "count",
            "count_distinct",
            "sum",
            "avg",
            "min",
            "max"
          ],
          "title": "Function",
          "type": "string"
        },
        "column": {
          "anyOf": [
            {
              "$ref": "#/$defs/QualifiedColumn"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        }
      },
      "required": [
        "function",
        "alias"
      ],
      "title": "AggregateProjection",
      "type": "object"
    },
    "ChildAggregate": {
      "additionalProperties": false,
      "properties": {
        "function": {
          "enum": [
            "count",
            "count_distinct",
            "sum",
            "avg",
            "min",
            "max"
          ],
          "title": "Function",
          "type": "string"
        },
        "column": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column"
        },
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        }
      },
      "required": [
        "function",
        "alias"
      ],
      "title": "ChildAggregate",
      "type": "object"
    },
    "ChildAggregation": {
      "additionalProperties": false,
      "properties": {
        "group_by": {
          "items": {
            "type": "string"
          },
          "title": "Group By",
          "type": "array"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "aggregates": {
          "items": {
            "$ref": "#/$defs/ChildAggregate"
          },
          "minItems": 1,
          "title": "Aggregates",
          "type": "array"
        }
      },
      "required": [
        "aggregates"
      ],
      "title": "ChildAggregation",
      "type": "object"
    },
    "ColumnProjection": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "column",
          "default": "column",
          "title": "Kind",
          "type": "string"
        },
        "column": {
          "$ref": "#/$defs/QualifiedColumn"
        },
        "alias": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alias"
        }
      },
      "required": [
        "column"
      ],
      "title": "ColumnProjection",
      "type": "object"
    },
    "JoinSpec": {
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "how": {
          "default": "left",
          "enum": [
            "inner",
            "left"
          ],
          "title": "How",
          "type": "string"
        },
        "aggregation": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChildAggregation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "dataset"
      ],
      "title": "JoinSpec",
      "type": "object"
    },
    "OrderBy": {
      "additionalProperties": false,
      "properties": {
        "output_alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Output Alias",
          "type": "string"
        },
        "direction": {
          "default": "asc",
          "enum": [
            "asc",
            "desc"
          ],
          "title": "Direction",
          "type": "string"
        }
      },
      "required": [
        "output_alias"
      ],
      "title": "OrderBy",
      "type": "object"
    },
    "QualifiedColumn": {
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "column": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Column",
          "type": "string"
        }
      },
      "required": [
        "dataset",
        "column"
      ],
      "title": "QualifiedColumn",
      "type": "object"
    },
    "TypedFilter": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "$ref": "#/$defs/QualifiedColumn"
        },
        "operator": {
          "enum": [
            "eq",
            "ne",
            "lt",
            "le",
            "gt",
            "ge",
            "in",
            "not_in",
            "between",
            "is_null",
            "is_not_null"
          ],
          "title": "Operator",
          "type": "string"
        },
        "value": {
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "column",
        "operator"
      ],
      "title": "TypedFilter",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "The only executable query input. There is intentionally no raw SQL field.",
  "properties": {
    "base_dataset": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "title": "Base Dataset",
      "type": "string"
    },
    "select": {
      "items": {
        "discriminator": {
          "mapping": {
            "aggregate": "#/$defs/AggregateProjection",
            "column": "#/$defs/ColumnProjection"
          },
          "propertyName": "kind"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/ColumnProjection"
          },
          {
            "$ref": "#/$defs/AggregateProjection"
          }
        ]
      },
      "minItems": 1,
      "title": "Select",
      "type": "array"
    },
    "filters": {
      "items": {
        "$ref": "#/$defs/TypedFilter"
      },
      "title": "Filters",
      "type": "array"
    },
    "joins": {
      "items": {
        "$ref": "#/$defs/JoinSpec"
      },
      "title": "Joins",
      "type": "array"
    },
    "group_by": {
      "items": {
        "$ref": "#/$defs/QualifiedColumn"
      },
      "title": "Group By",
      "type": "array"
    },
    "order_by": {
      "items": {
        "$ref": "#/$defs/OrderBy"
      },
      "title": "Order By",
      "type": "array"
    },
    "limit": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Limit"
    }
  },
  "required": [
    "base_dataset",
    "select"
  ],
  "title": "QuerySpec",
  "type": "object"
}