{
  "$defs": {
    "AnalysisPlan": {
      "additionalProperties": false,
      "description": "Structured, non-SQL analysis contract accepted before deterministic compilation.",
      "properties": {
        "comparisons": {
          "$ref": "#/$defs/ComparisonSpec"
        },
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "denominator": {
          "$ref": "#/$defs/DenominatorSpec"
        },
        "derived_recodes": {
          "items": {
            "$ref": "#/$defs/DerivedRecodeSpec"
          },
          "title": "Derived Recodes",
          "type": "array"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "grouping_dimensions": {
          "items": {
            "$ref": "#/$defs/QualifiedColumn"
          },
          "title": "Grouping Dimensions",
          "type": "array"
        },
        "joins": {
          "items": {
            "$ref": "#/$defs/JoinSpec"
          },
          "title": "Joins",
          "type": "array"
        },
        "measure": {
          "$ref": "#/$defs/MeasureSpec"
        },
        "numerator": {
          "$ref": "#/$defs/NumeratorSpec"
        },
        "output_format": {
          "$ref": "#/$defs/OutputFormatSpec"
        },
        "plan_version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Plan Version",
          "type": "string"
        },
        "required_variables": {
          "items": {
            "$ref": "#/$defs/QualifiedColumn"
          },
          "minItems": 1,
          "title": "Required Variables",
          "type": "array"
        },
        "universe": {
          "$ref": "#/$defs/UniverseSpec"
        },
        "user_question": {
          "minLength": 3,
          "title": "User Question",
          "type": "string"
        },
        "validation_checks": {
          "$ref": "#/$defs/ValidationChecks"
        },
        "weight": {
          "$ref": "#/$defs/WeightSpec"
        }
      },
      "required": [
        "user_question",
        "dataset",
        "measure",
        "numerator",
        "denominator",
        "universe",
        "weight",
        "required_variables"
      ],
      "title": "AnalysisPlan",
      "type": "object"
    },
    "AnalysisPlanExecutionResult": {
      "additionalProperties": false,
      "properties": {
        "output_format": {
          "$ref": "#/$defs/OutputFormatSpec"
        },
        "plan": {
          "$ref": "#/$defs/AnalysisPlan"
        },
        "plan_fingerprint": {
          "title": "Plan Fingerprint",
          "type": "string"
        },
        "result": {
          "$ref": "#/$defs/SurveyEstimateResult"
        },
        "validation_messages": {
          "items": {
            "type": "string"
          },
          "title": "Validation Messages",
          "type": "array"
        }
      },
      "required": [
        "plan",
        "plan_fingerprint",
        "validation_messages",
        "output_format",
        "result"
      ],
      "title": "AnalysisPlanExecutionResult",
      "type": "object"
    },
    "ApprovalDecision": {
      "additionalProperties": false,
      "properties": {
        "decision": {
          "enum": [
            "approved",
            "rejected",
            "revise"
          ],
          "title": "Decision",
          "type": "string"
        },
        "feedback": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Feedback"
        }
      },
      "required": [
        "decision"
      ],
      "title": "ApprovalDecision",
      "type": "object"
    },
    "ChildAggregate": {
      "additionalProperties": false,
      "properties": {
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        },
        "column": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column"
        },
        "function": {
          "enum": [
            "count",
            "count_distinct",
            "sum",
            "avg",
            "min",
            "max"
          ],
          "title": "Function",
          "type": "string"
        }
      },
      "required": [
        "function",
        "alias"
      ],
      "title": "ChildAggregate",
      "type": "object"
    },
    "ChildAggregation": {
      "additionalProperties": false,
      "properties": {
        "aggregates": {
          "items": {
            "$ref": "#/$defs/ChildAggregate"
          },
          "minItems": 1,
          "title": "Aggregates",
          "type": "array"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "group_by": {
          "items": {
            "type": "string"
          },
          "title": "Group By",
          "type": "array"
        }
      },
      "required": [
        "aggregates"
      ],
      "title": "ChildAggregation",
      "type": "object"
    },
    "ComparisonSpec": {
      "additionalProperties": false,
      "properties": {
        "include_ratio": {
          "default": true,
          "title": "Include Ratio",
          "type": "boolean"
        },
        "mode": {
          "default": "none",
          "enum": [
            "none",
            "reference",
            "all_pairs"
          ],
          "title": "Mode",
          "type": "string"
        },
        "reference_group": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Group"
        }
      },
      "title": "ComparisonSpec",
      "type": "object"
    },
    "CompiledSurveyEstimate": {
      "additionalProperties": false,
      "properties": {
        "canonical_request": {
          "additionalProperties": true,
          "title": "Canonical Request",
          "type": "object"
        },
        "datasets_used": {
          "items": {
            "type": "string"
          },
          "title": "Datasets Used",
          "type": "array"
        },
        "display_sql": {
          "title": "Display Sql",
          "type": "string"
        },
        "effective_limit": {
          "title": "Effective Limit",
          "type": "integer"
        },
        "formulas": {
          "items": {
            "$ref": "#/$defs/FormulaDescriptor"
          },
          "title": "Formulas",
          "type": "array"
        },
        "group_aliases": {
          "items": {
            "type": "string"
          },
          "title": "Group Aliases",
          "type": "array"
        },
        "join_contract_ids": {
          "items": {
            "type": "string"
          },
          "title": "Join Contract Ids",
          "type": "array"
        },
        "normalized_reference_group": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "title": "Normalized Reference Group"
        },
        "parameters": {
          "items": {},
          "title": "Parameters",
          "type": "array"
        },
        "request_fingerprint": {
          "title": "Request Fingerprint",
          "type": "string"
        },
        "sql": {
          "title": "Sql",
          "type": "string"
        }
      },
      "required": [
        "sql",
        "display_sql",
        "parameters",
        "effective_limit",
        "canonical_request",
        "request_fingerprint",
        "datasets_used",
        "join_contract_ids",
        "group_aliases",
        "normalized_reference_group",
        "formulas"
      ],
      "title": "CompiledSurveyEstimate",
      "type": "object"
    },
    "DatasetEstimateMetadata": {
      "additionalProperties": false,
      "properties": {
        "logical_name": {
          "title": "Logical Name",
          "type": "string"
        },
        "modified_ns": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Modified Ns"
        },
        "physical_path": {
          "title": "Physical Path",
          "type": "string"
        },
        "size_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Size Bytes"
        },
        "source_file_id": {
          "title": "Source File Id",
          "type": "string"
        },
        "synthetic_fixture": {
          "title": "Synthetic Fixture",
          "type": "boolean"
        }
      },
      "required": [
        "logical_name",
        "source_file_id",
        "physical_path",
        "synthetic_fixture",
        "size_bytes",
        "modified_ns"
      ],
      "title": "DatasetEstimateMetadata",
      "type": "object"
    },
    "DenominatorSpec": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "role": {
          "enum": [
            "eligible_units",
            "nonmissing_weight_sum"
          ],
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role",
        "description"
      ],
      "title": "DenominatorSpec",
      "type": "object"
    },
    "DerivedRecodeSpec": {
      "additionalProperties": false,
      "properties": {
        "output_name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Output Name",
          "type": "string"
        },
        "purpose": {
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        },
        "recode_id": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Recode Id",
          "type": "string"
        }
      },
      "required": [
        "recode_id",
        "output_name",
        "purpose"
      ],
      "title": "DerivedRecodeSpec",
      "type": "object"
    },
    "EstimateDefinition": {
      "additionalProperties": false,
      "properties": {
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        },
        "denominator_filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Denominator Filters",
          "type": "array"
        },
        "missing_value_rules": {
          "items": {
            "$ref": "#/$defs/MissingValueRule"
          },
          "title": "Missing Value Rules",
          "type": "array"
        },
        "numerator_filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Numerator Filters",
          "type": "array"
        },
        "statistic": {
          "enum": [
            "weighted_count",
            "weighted_percentage",
            "weighted_mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/QualifiedColumn"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "alias",
        "statistic"
      ],
      "title": "EstimateDefinition",
      "type": "object"
    },
    "FormulaDescriptor": {
      "additionalProperties": false,
      "properties": {
        "denominator_formula": {
          "title": "Denominator Formula",
          "type": "string"
        },
        "estimate_alias": {
          "title": "Estimate Alias",
          "type": "string"
        },
        "estimate_formula": {
          "title": "Estimate Formula",
          "type": "string"
        },
        "missing_value_rule": {
          "title": "Missing Value Rule",
          "type": "string"
        },
        "numerator_formula": {
          "title": "Numerator Formula",
          "type": "string"
        },
        "statistic": {
          "enum": [
            "weighted_count",
            "weighted_percentage",
            "weighted_mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "weight_rule": {
          "title": "Weight Rule",
          "type": "string"
        }
      },
      "required": [
        "estimate_alias",
        "statistic",
        "numerator_formula",
        "denominator_formula",
        "estimate_formula",
        "missing_value_rule",
        "weight_rule"
      ],
      "title": "FormulaDescriptor",
      "type": "object"
    },
    "GroupComparison": {
      "additionalProperties": false,
      "properties": {
        "difference": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Difference"
        },
        "estimate_alias": {
          "title": "Estimate Alias",
          "type": "string"
        },
        "inferential_test": {
          "const": "NOT_PERFORMED",
          "default": "NOT_PERFORMED",
          "title": "Inferential Test",
          "type": "string"
        },
        "left_group": {
          "additionalProperties": true,
          "title": "Left Group",
          "type": "object"
        },
        "p_value": {
          "default": null,
          "title": "P Value",
          "type": "null"
        },
        "ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Ratio"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "right_group": {
          "additionalProperties": true,
          "title": "Right Group",
          "type": "object"
        },
        "standard_error": {
          "default": null,
          "title": "Standard Error",
          "type": "null"
        },
        "statistic": {
          "enum": [
            "weighted_count",
            "weighted_percentage",
            "weighted_mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "suppressed": {
          "title": "Suppressed",
          "type": "boolean"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "estimate_alias",
        "statistic",
        "left_group",
        "right_group",
        "difference",
        "ratio",
        "suppressed",
        "reasons"
      ],
      "title": "GroupComparison",
      "type": "object"
    },
    "GroupDimension": {
      "additionalProperties": false,
      "properties": {
        "alias": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alias"
        },
        "column": {
          "$ref": "#/$defs/QualifiedColumn"
        }
      },
      "required": [
        "column"
      ],
      "title": "GroupDimension",
      "type": "object"
    },
    "JoinSpec": {
      "additionalProperties": false,
      "properties": {
        "aggregation": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChildAggregation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "how": {
          "default": "left",
          "enum": [
            "inner",
            "left"
          ],
          "title": "How",
          "type": "string"
        }
      },
      "required": [
        "dataset"
      ],
      "title": "JoinSpec",
      "type": "object"
    },
    "MeasureSpec": {
      "additionalProperties": false,
      "properties": {
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        },
        "statistic": {
          "enum": [
            "count",
            "percentage",
            "mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/QualifiedColumn"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "alias",
        "statistic"
      ],
      "title": "MeasureSpec",
      "type": "object"
    },
    "MissingValueRule": {
      "additionalProperties": false,
      "properties": {
        "codes": {
          "items": {},
          "title": "Codes",
          "type": "array"
        },
        "column": {
          "$ref": "#/$defs/QualifiedColumn"
        }
      },
      "required": [
        "column"
      ],
      "title": "MissingValueRule",
      "type": "object"
    },
    "NumeratorSpec": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "role": {
          "enum": [
            "eligible_units",
            "condition_true",
            "weighted_value_sum"
          ],
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role",
        "description"
      ],
      "title": "NumeratorSpec",
      "type": "object"
    },
    "OutputFormatSpec": {
      "additionalProperties": false,
      "properties": {
        "format": {
          "default": "json_records",
          "enum": [
            "json_records",
            "table"
          ],
          "title": "Format",
          "type": "string"
        },
        "include_analysis_plan": {
          "default": true,
          "title": "Include Analysis Plan",
          "type": "boolean"
        },
        "include_execution_metadata": {
          "default": true,
          "title": "Include Execution Metadata",
          "type": "boolean"
        },
        "include_formula_metadata": {
          "default": true,
          "title": "Include Formula Metadata",
          "type": "boolean"
        },
        "include_generated_sql": {
          "default": true,
          "title": "Include Generated Sql",
          "type": "boolean"
        },
        "limit": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Limit"
        }
      },
      "title": "OutputFormatSpec",
      "type": "object"
    },
    "QualifiedColumn": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Column",
          "type": "string"
        },
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        }
      },
      "required": [
        "dataset",
        "column"
      ],
      "title": "QualifiedColumn",
      "type": "object"
    },
    "ResultCheck": {
      "additionalProperties": false,
      "properties": {
        "check_id": {
          "title": "Check Id",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        }
      },
      "required": [
        "check_id",
        "passed",
        "message"
      ],
      "title": "ResultCheck",
      "type": "object"
    },
    "ResultCheckReport": {
      "additionalProperties": false,
      "properties": {
        "checks": {
          "items": {
            "$ref": "#/$defs/ResultCheck"
          },
          "title": "Checks",
          "type": "array"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        }
      },
      "required": [
        "passed",
        "checks"
      ],
      "title": "ResultCheckReport",
      "type": "object"
    },
    "ResultCriticCheck": {
      "additionalProperties": false,
      "properties": {
        "check_id": {
          "title": "Check Id",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "not_applicable"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "check_id",
        "status",
        "message"
      ],
      "title": "ResultCriticCheck",
      "type": "object"
    },
    "ResultCriticReport": {
      "additionalProperties": false,
      "properties": {
        "checks": {
          "items": {
            "$ref": "#/$defs/ResultCriticCheck"
          },
          "title": "Checks",
          "type": "array"
        },
        "decision": {
          "enum": [
            "approve",
            "reject",
            "request_reexecution"
          ],
          "title": "Decision",
          "type": "string"
        },
        "failed_check_ids": {
          "items": {
            "type": "string"
          },
          "title": "Failed Check Ids",
          "type": "array"
        },
        "max_reexecutions": {
          "minimum": 0,
          "title": "Max Reexecutions",
          "type": "integer"
        },
        "numeric_results_unchanged": {
          "const": true,
          "default": true,
          "title": "Numeric Results Unchanged",
          "type": "boolean"
        },
        "reexecution_count": {
          "minimum": 0,
          "title": "Reexecution Count",
          "type": "integer"
        }
      },
      "required": [
        "decision",
        "checks",
        "reexecution_count",
        "max_reexecutions"
      ],
      "title": "ResultCriticReport",
      "type": "object"
    },
    "SuppressionDecision": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "flag",
            "null_estimate"
          ],
          "title": "Action",
          "type": "string"
        },
        "policy_id": {
          "title": "Policy Id",
          "type": "string"
        },
        "reasons": {
          "items": {
            "type": "string"
