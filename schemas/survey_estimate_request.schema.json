{
  "$defs": {
    "ChildAggregate": {
      "additionalProperties": false,
      "properties": {
        "function": {
          "enum": [
            "count",
            "count_distinct",
            "sum",
            "avg",
            "min",
            "max"
          ],
          "title": "Function",
          "type": "string"
        },
        "column": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column"
        },
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        }
      },
      "required": [
        "function",
        "alias"
      ],
      "title": "ChildAggregate",
      "type": "object"
    },
    "ChildAggregation": {
      "additionalProperties": false,
      "properties": {
        "group_by": {
          "items": {
            "type": "string"
          },
          "title": "Group By",
          "type": "array"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "aggregates": {
          "items": {
            "$ref": "#/$defs/ChildAggregate"
          },
          "minItems": 1,
          "title": "Aggregates",
          "type": "array"
        }
      },
      "required": [
        "aggregates"
      ],
      "title": "ChildAggregation",
      "type": "object"
    },
    "ComparisonSpec": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "default": "none",
          "enum": [
            "none",
            "reference",
            "all_pairs"
          ],
          "title": "Mode",
          "type": "string"
        },
        "reference_group": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Group"
        },
        "include_ratio": {
          "default": true,
          "title": "Include Ratio",
          "type": "boolean"
        }
      },
      "title": "ComparisonSpec",
      "type": "object"
    },
    "EstimateDefinition": {
      "additionalProperties": false,
      "properties": {
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        },
        "statistic": {
          "enum": [
            "weighted_count",
            "weighted_percentage",
            "weighted_mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "numerator_filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Numerator Filters",
          "type": "array"
        },
        "denominator_filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Denominator Filters",
          "type": "array"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/QualifiedColumn"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "missing_value_rules": {
          "items": {
            "$ref": "#/$defs/MissingValueRule"
          },
          "title": "Missing Value Rules",
          "type": "array"
        }
      },
      "required": [
        "alias",
        "statistic"
      ],
      "title": "EstimateDefinition",
      "type": "object"
    },
    "GroupDimension": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "$ref": "#/$defs/QualifiedColumn"
        },
        "alias": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alias"
        }
      },
      "required": [
        "column"
      ],
      "title": "GroupDimension",
      "type": "object"
    },
    "JoinSpec": {
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "how": {
          "default": "left",
          "enum": [
            "inner",
            "left"
          ],
          "title": "How",
          "type": "string"
        },
        "aggregation": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChildAggregation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "dataset"
      ],
      "title": "JoinSpec",
      "type": "object"
    },
    "MissingValueRule": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "$ref": "#/$defs/QualifiedColumn"
        },
        "codes": {
          "items": {},
          "title": "Codes",
          "type": "array"
        }
      },
      "required": [
        "column"
      ],
      "title": "MissingValueRule",
      "type": "object"
    },
    "QualifiedColumn": {
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "column": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Column",
          "type": "string"
        }
      },
      "required": [
        "dataset",
        "column"
      ],
      "title": "QualifiedColumn",
      "type": "object"
    },
    "SuppressionPolicy": {
      "additionalProperties": false,
      "properties": {
        "policy_id": {
          "default": "configured_unweighted_cell_thresholds_v1",
          "title": "Policy Id",
          "type": "string"
        },
        "minimum_unweighted_denominator": {
          "default": 1,
          "minimum": 0,
          "title": "Minimum Unweighted Denominator",
          "type": "integer"
        },
        "minimum_unweighted_numerator": {
          "default": 0,
          "minimum": 0,
          "title": "Minimum Unweighted Numerator",
          "type": "integer"
        },
        "minimum_unweighted_complement": {
          "default": 0,
          "minimum": 0,
          "title": "Minimum Unweighted Complement",
          "type": "integer"
        },
        "action": {
          "default": "null_estimate",
          "enum": [
            "flag",
            "null_estimate"
          ],
          "title": "Action",
          "type": "string"
        }
      },
      "title": "SuppressionPolicy",
      "type": "object"
    },
    "TypedFilter": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "$ref": "#/$defs/QualifiedColumn"
        },
        "operator": {
          "enum": [
            "eq",
            "ne",
            "lt",
            "le",
            "gt",
            "ge",
            "in",
            "not_in",
            "between",
            "is_null",
            "is_not_null"
          ],
          "title": "Operator",
          "type": "string"
        },
        "value": {
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "column",
        "operator"
      ],
      "title": "TypedFilter",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Governed descriptive-estimation input. Raw SQL is intentionally impossible.",
  "properties": {
    "base_dataset": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "title": "Base Dataset",
      "type": "string"
    },
    "weighting_mode": {
      "default": "weighted",
      "enum": [
        "weighted",
        "unweighted"
      ],
      "title": "Weighting Mode",
      "type": "string"
    },
    "weight": {
      "anyOf": [
        {
          "$ref": "#/$defs/QualifiedColumn"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "universe_filters": {
      "items": {
        "$ref": "#/$defs/TypedFilter"
      },
      "title": "Universe Filters",
      "type": "array"
    },
    "joins": {
      "items": {
        "$ref": "#/$defs/JoinSpec"
      },
      "title": "Joins",
      "type": "array"
    },
    "group_by": {
      "items": {
        "$ref": "#/$defs/GroupDimension"
      },
      "title": "Group By",
      "type": "array"
    },
    "estimates": {
      "items": {
        "$ref": "#/$defs/EstimateDefinition"
      },
      "minItems": 1,
      "title": "Estimates",
      "type": "array"
    },
    "suppression": {
      "anyOf": [
        {
          "$ref": "#/$defs/SuppressionPolicy"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "comparisons": {
      "$ref": "#/$defs/ComparisonSpec"
    },
    "limit": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Limit"
    }
  },
  "required": [
    "base_dataset",
    "estimates"
  ],
  "title": "SurveyEstimateRequest",
  "type": "object"
}