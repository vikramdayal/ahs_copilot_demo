{
  "$defs": {
    "AnalysisPlan": {
      "additionalProperties": false,
      "description": "Structured, non-SQL analysis contract accepted before deterministic compilation.",
      "properties": {
        "comparisons": {
          "$ref": "#/$defs/ComparisonSpec"
        },
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "denominator": {
          "$ref": "#/$defs/DenominatorSpec"
        },
        "derived_recodes": {
          "items": {
            "$ref": "#/$defs/DerivedRecodeSpec"
          },
          "title": "Derived Recodes",
          "type": "array"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "grouping_dimensions": {
          "items": {
            "$ref": "#/$defs/QualifiedColumn"
          },
          "title": "Grouping Dimensions",
          "type": "array"
        },
        "joins": {
          "items": {
            "$ref": "#/$defs/JoinSpec"
          },
          "title": "Joins",
          "type": "array"
        },
        "measure": {
          "$ref": "#/$defs/MeasureSpec"
        },
        "numerator": {
          "$ref": "#/$defs/NumeratorSpec"
        },
        "output_format": {
          "$ref": "#/$defs/OutputFormatSpec"
        },
        "plan_version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Plan Version",
          "type": "string"
        },
        "required_variables": {
          "items": {
            "$ref": "#/$defs/QualifiedColumn"
          },
          "minItems": 1,
          "title": "Required Variables",
          "type": "array"
        },
        "universe": {
          "$ref": "#/$defs/UniverseSpec"
        },
        "user_question": {
          "minLength": 3,
          "title": "User Question",
          "type": "string"
        },
        "validation_checks": {
          "$ref": "#/$defs/ValidationChecks"
        },
        "weight": {
          "$ref": "#/$defs/WeightSpec"
        }
      },
      "required": [
        "user_question",
        "dataset",
        "measure",
        "numerator",
        "denominator",
        "universe",
        "weight",
        "required_variables"
      ],
      "title": "AnalysisPlan",
      "type": "object"
    },
    "ChildAggregate": {
      "additionalProperties": false,
      "properties": {
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        },
        "column": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column"
        },
        "function": {
          "enum": [
            "count",
            "count_distinct",
            "sum",
            "avg",
            "min",
            "max"
          ],
          "title": "Function",
          "type": "string"
        }
      },
      "required": [
        "function",
        "alias"
      ],
      "title": "ChildAggregate",
      "type": "object"
    },
    "ChildAggregation": {
      "additionalProperties": false,
      "properties": {
        "aggregates": {
          "items": {
            "$ref": "#/$defs/ChildAggregate"
          },
          "minItems": 1,
          "title": "Aggregates",
          "type": "array"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "group_by": {
          "items": {
            "type": "string"
          },
          "title": "Group By",
          "type": "array"
        }
      },
      "required": [
        "aggregates"
      ],
      "title": "ChildAggregation",
      "type": "object"
    },
    "ComparisonSpec": {
      "additionalProperties": false,
      "properties": {
        "include_ratio": {
          "default": true,
          "title": "Include Ratio",
          "type": "boolean"
        },
        "mode": {
          "default": "none",
          "enum": [
            "none",
            "reference",
            "all_pairs"
          ],
          "title": "Mode",
          "type": "string"
        },
        "reference_group": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Group"
        }
      },
      "title": "ComparisonSpec",
      "type": "object"
    },
    "DenominatorSpec": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "role": {
          "enum": [
            "eligible_units",
            "nonmissing_weight_sum"
          ],
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role",
        "description"
      ],
      "title": "DenominatorSpec",
      "type": "object"
    },
    "DerivedRecodeSpec": {
      "additionalProperties": false,
      "properties": {
        "output_name": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Output Name",
          "type": "string"
        },
        "purpose": {
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        },
        "recode_id": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Recode Id",
          "type": "string"
        }
      },
      "required": [
        "recode_id",
        "output_name",
        "purpose"
      ],
      "title": "DerivedRecodeSpec",
      "type": "object"
    },
    "JoinSpec": {
      "additionalProperties": false,
      "properties": {
        "aggregation": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChildAggregation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        },
        "how": {
          "default": "left",
          "enum": [
            "inner",
            "left"
          ],
          "title": "How",
          "type": "string"
        }
      },
      "required": [
        "dataset"
      ],
      "title": "JoinSpec",
      "type": "object"
    },
    "MeasureSpec": {
      "additionalProperties": false,
      "properties": {
        "alias": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Alias",
          "type": "string"
        },
        "statistic": {
          "enum": [
            "count",
            "percentage",
            "mean"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/QualifiedColumn"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "alias",
        "statistic"
      ],
      "title": "MeasureSpec",
      "type": "object"
    },
    "NumeratorSpec": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/TypedFilter"
          },
          "title": "Filters",
          "type": "array"
        },
        "role": {
          "enum": [
            "eligible_units",
            "condition_true",
            "weighted_value_sum"
          ],
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role",
        "description"
      ],
      "title": "NumeratorSpec",
      "type": "object"
    },
    "OutputFormatSpec": {
      "additionalProperties": false,
      "properties": {
        "format": {
          "default": "json_records",
          "enum": [
            "json_records",
            "table"
          ],
          "title": "Format",
          "type": "string"
        },
        "include_analysis_plan": {
          "default": true,
          "title": "Include Analysis Plan",
          "type": "boolean"
        },
        "include_execution_metadata": {
          "default": true,
          "title": "Include Execution Metadata",
          "type": "boolean"
        },
        "include_formula_metadata": {
          "default": true,
          "title": "Include Formula Metadata",
          "type": "boolean"
        },
        "include_generated_sql": {
          "default": true,
          "title": "Include Generated Sql",
          "type": "boolean"
        },
        "limit": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Limit"
        }
      },
      "title": "OutputFormatSpec",
      "type": "object"
    },
    "QualifiedColumn": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Column",
          "type": "string"
        },
        "dataset": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Dataset",
          "type": "string"
        }
      },
      "required": [
        "dataset",
        "column"
      ],
      "title": "QualifiedColumn",
      "type": "object"
    },
    "TypedFilter": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "$ref": "#/$defs/QualifiedColumn"
        },
        "operator": {
          "enum": [
            "eq",
            "ne",
            "lt",
            "le",
            "gt",
            "ge",
            "in",
            "not_in",
            "between",
            "is_null",
            "is_not_null"
          ],
          "title": "Operator",
          "type": "string"
        },
        "value": {
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "column",
        "operator"
      ],
      "title": "TypedFilter",
      "type": "object"
    },
    "UniverseSpec": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "universe_id": {
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
          "title": "Universe Id",
          "type": "string"
        }
      },
      "required": [
        "universe_id",
        "description"
      ],
      "title": "UniverseSpec",
      "type": "object"
    },
    "ValidationChecks": {
      "additionalProperties": false,
      "properties": {
        "approved_join_paths": {
          "const": true,
          "default": true,
          "title": "Approved Join Paths",
          "type": "boolean"
        },
        "empty_denominator_runtime_flag": {
          "const": true,
          "default": true,
          "title": "Empty Denominator Runtime Flag",
          "type": "boolean"
        },
        "measure_compatibility": {
          "const": true,
          "default": true,
          "title": "Measure Compatibility",
          "type": "boolean"
        },
        "missing_value_codes": {
          "const": true,
          "default": true,
          "title": "Missing Value Codes",
          "type": "boolean"
        },
        "numerator_denominator_compatibility": {
          "const": true,
          "default": true,
          "title": "Numerator Denominator Compatibility",
          "type": "boolean"
        },
        "puf_access": {
          "const": true,
          "default": true,
          "title": "Puf Access",
          "type": "boolean"
        },
        "required_variable_closure": {
          "const": true,
          "default": true,
          "title": "Required Variable Closure",
          "type": "boolean"
        },
        "schema_variables": {
          "const": true,
          "default": true,
          "title": "Schema Variables",
          "type": "boolean"
        },
        "universe_compatibility": {
          "const": true,
          "default": true,
          "title": "Universe Compatibility",
          "type": "boolean"
        },
        "weight_compatibility": {
          "const": true,
          "default": true,
          "title": "Weight Compatibility",
          "type": "boolean"
        }
      },
      "title": "ValidationChecks",
      "type": "object"
    },
    "WeightSpec": {
      "additionalProperties": false,
      "properties": {
        "column": {
          "anyOf": [
            {
              "$ref": "#/$defs/QualifiedColumn"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mode": {
          "enum": [
            "weighted",
            "unweighted"
          ],
          "title": "Mode",
          "type": "string"
        }
      },
      "required": [
        "mode"
      ],
      "title": "WeightSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "allowed_decisions": {
      "items": {
        "enum": [
          "approved",
          "rejected",
          "revise"
        ],
        "type": "string"
      },
      "title": "Allowed Decisions",
      "type": "array"
    },
    "attempt": {
      "title": "Attempt",
      "type": "integer"
    },
    "plan": {
      "$ref": "#/$defs/AnalysisPlan"
    },
    "plan_fingerprint": {
      "title": "Plan Fingerprint",
      "type": "string"
    },
    "question": {
      "title": "Question",
      "type": "string"
    },
    "request_type": {
      "const": "analysis_plan_approval",
      "default": "analysis_plan_approval",
      "title": "Request Type",
      "type": "string"
    },
    "validation_messages": {
      "items": {
        "type": "string"
      },
      "title": "Validation Messages",
      "type": "array"
    }
  },
  "required": [
    "question",
    "attempt",
    "plan",
    "plan_fingerprint",
    "validation_messages"
  ],
  "title": "ApprovalRequest",
  "type": "object"
}
