{
  "base_dataset": "household",
  "columns": [
    {
      "column": "CONTROL"
    },
    {
      "dataset": "projects",
      "column": "project_count"
    },
    {
      "dataset": "projects",
      "column": "total_project_cost"
    }
  ],
  "joins": [
    {
      "relationship_id": "rel_household_projects_control",
      "aggregates": [
        {
          "function": "count",
          "alias": "project_count"
        },
        {
          "function": "sum",
          "column": "JOBCOST",
          "alias": "total_project_cost"
        }
      ]
    }
  ],
  "order_by": [
    {
      "output": "CONTROL",
      "direction": "asc"
    }
  ],
  "limit": 100
}
