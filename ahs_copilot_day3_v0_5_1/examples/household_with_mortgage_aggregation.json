{
  "base_dataset": "household",
  "columns": [
    {
      "column": "CONTROL"
    },
    {
      "dataset": "mortgage",
      "column": "mortgage_count"
    },
    {
      "dataset": "mortgage",
      "column": "total_mortgage_amount"
    }
  ],
  "joins": [
    {
      "relationship_id": "rel_household_mortgage_control",
      "aggregates": [
        {
          "function": "count",
          "alias": "mortgage_count"
        },
        {
          "function": "sum",
          "column": "MORTAMT",
          "alias": "total_mortgage_amount"
        }
      ]
    }
  ],
  "order_by": [
    {
      "output": "CONTROL",
      "direction": "asc"
    }
  ],
  "limit": 100
}
