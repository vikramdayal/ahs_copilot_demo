{
  "$defs": {
    "AnalysisPlan": {
      "additionalProperties": false,
      "properties": {
        "user_question": {
          "title": "User Question",
          "type": "string"
        },
        "dataset": {
          "title": "Dataset",
          "type": "string"
        },
        "measure": {
          "enum": [
            "count",
            "percentage",
            "mean"
          ],
          "title": "Measure",
          "type": "string"
        },
        "numerator": {
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "title": "Numerator",
          "type": "array"
        },
        "denominator": {
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "title": "Denominator",
          "type": "array"
        },
        "universe": {
          "title": "Universe",
          "type": "string"
        },
        "filters": {
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "title": "Filters",
          "type": "array"
        },
        "grouping_dimensions": {
          "items": {
            "type": "string"
          },
          "title": "Grouping Dimensions",
          "type": "array"
        },
        "weight": {
          "title": "Weight",
          "type": "string"
        },
        "required_variables": {
          "items": {
            "type": "string"
          },
          "title": "Required Variables",
          "type": "array"
        },
        "derived_recodes": {
          "items": {
            "type": "string"
          },
          "title": "Derived Recodes",
          "type": "array"
        },
        "validation_checks": {
          "items": {
            "type": "string"
          },
          "title": "Validation Checks",
          "type": "array"
        },
        "output_format": {
          "default": "json",
          "enum": [
            "json",
            "table"
          ],
          "title": "Output Format",
          "type": "string"
        },
        "value_variable": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value Variable"
        }
      },
      "required": [
        "user_question",
        "dataset",
        "measure",
        "universe",
        "weight",
        "required_variables"
      ],
      "title": "AnalysisPlan",
      "type": "object"
    },
    "Condition": {
      "additionalProperties": false,
      "properties": {
        "variable": {
          "title": "Variable",
          "type": "string"
        },
        "operator": {
          "enum": [
            "eq",
            "ne",
            "gt",
            "ge",
            "lt",
            "le",
            "in",
            "not_in",
            "between",
            "is_null",
            "not_null"
          ],
          "title": "Operator",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "values": {
          "anyOf": [
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Values"
        },
        "lower": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower"
        },
        "upper": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Upper"
        }
      },
      "required": [
        "variable",
        "operator"
      ],
      "title": "Condition",
      "type": "object"
    },
    "SurveyEstimateRequest": {
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "default": "household",
          "title": "Dataset",
          "type": "string"
        },
        "measure": {
          "enum": [
            "count",
            "percentage",
            "mean"
          ],
          "title": "Measure",
          "type": "string"
        },
        "universe_id": {
          "title": "Universe Id",
          "type": "string"
        },
        "numerator_conditions": {
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "title": "Numerator Conditions",
          "type": "array"
        },
        "denominator_conditions": {
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "title": "Denominator Conditions",
          "type": "array"
        },
        "grouping_dimensions": {
          "items": {
            "type": "string"
          },
          "title": "Grouping Dimensions",
          "type": "array"
        },
        "weight_id": {
          "default": "final_household_weight",
          "title": "Weight Id",
          "type": "string"
        },
        "value_variable": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value Variable"
        },
        "minimum_unweighted_n": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum Unweighted N"
        }
      },
      "required": [
        "measure",
        "universe_id"
      ],
      "title": "SurveyEstimateRequest",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "plan": {
      "$ref": "#/$defs/AnalysisPlan"
    },
    "normalized_request": {
      "$ref": "#/$defs/SurveyEstimateRequest"
    },
    "required_variable_closure": {
      "items": {
        "type": "string"
      },
      "title": "Required Variable Closure",
      "type": "array"
    },
    "validation_checks": {
      "items": {
        "type": "string"
      },
      "title": "Validation Checks",
      "type": "array"
    }
  },
  "required": [
    "plan",
    "normalized_request",
    "required_variable_closure",
    "validation_checks"
  ],
  "title": "ValidatedAnalysisPlan",
  "type": "object"
}
